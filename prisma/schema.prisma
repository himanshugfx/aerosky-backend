generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String                 @id @default(uuid())
  username              String                 @unique
  email                 String?                @unique
  fullName              String?                @map("full_name")
  phone                 String?
  passwordHash          String                 @map("password_hash")
  role                  Role                   @default(ADMINISTRATION)
  isActive              Boolean                @default(true) @map("is_active")
  teamMemberId          String?                @unique @map("team_member_id")
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  inventoryTransactions InventoryTransaction[]
  reimbursements        Reimbursement[]
  supportTickets        SupportTicket[]
  teamMember            TeamMember?            @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)

  @@map("users")
}

model Permission {
  id              String           @id @default(uuid())
  name            String           @unique
  description     String?
  category        String
  createdAt       DateTime         @default(now()) @map("created_at")
  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid())
  role         Role
  permissionId String     @map("permission_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
  @@map("role_permissions")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  action     String
  resource   String
  resourceId String?  @map("resource_id")
  details    Json?
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model TeamMember {
  id         String      @id @default(uuid())
  accessId   String      @unique @map("access_id")
  name       String
  phone      String?
  email      String?
  position   String?
  createdAt  DateTime    @default(now()) @map("created_at")
  drones     Drone[]     @relation("AccountableManager")
  picFlights FlightLog[] @relation("PIC")
  voFlights  FlightLog[] @relation("VO")
  user       User?

  @@map("team_members")
}

model Subcontractor {
  id                    String                 @id @default(uuid())
  companyName           String                 @map("company_name")
  type                  String
  contactPerson         String?                @map("contact_person")
  contactEmail          String?                @map("contact_email")
  contactPhone          String?                @map("contact_phone")
  agreementDate         String?                @map("agreement_date")
  createdAt             DateTime               @default(now()) @map("created_at")
  inventoryTransactions InventoryTransaction[]

  @@map("subcontractors")
}

model Drone {
  id                   String             @id @default(uuid())
  modelName            String             @map("model_name")
  image                String?
  accountableManagerId String?            @map("accountable_manager_id")
  webPortalLink        String?            @map("web_portal_link")
  isDgcaCertified      Boolean            @default(false) @map("is_dgca_certified")
  createdAt            DateTime           @default(now()) @map("created_at")
  recurringData        Json?              @map("recurring_data")
  uploads              DroneUpload[]
  accountableManager   TeamMember?        @relation("AccountableManager", fields: [accountableManagerId], references: [id])
  flightLogs           FlightLog[]
  manufacturedUnits    ManufacturedUnit[]

  @@map("drones")
}

model ManufacturedUnit {
  id           String   @id @default(uuid())
  droneId      String   @map("drone_id")
  serialNumber String   @map("serial_number")
  uin          String   @map("uin")
  createdAt    DateTime @default(now()) @map("created_at")
  drone        Drone    @relation(fields: [droneId], references: [id], onDelete: Cascade)

  @@map("manufactured_units")
}

model DroneUpload {
  id         String   @id @default(uuid())
  droneId    String   @map("drone_id")
  uploadType String   @map("upload_type")
  fileData   String   @map("file_data")
  label      String?
  createdAt  DateTime @default(now()) @map("created_at")
  drone      Drone    @relation(fields: [droneId], references: [id], onDelete: Cascade)

  @@map("drone_uploads")
}

model Battery {
  id             String      @id @default(uuid())
  model          String
  ratedCapacity  String      @map("rated_capacity")
  batteryNumberA String      @map("battery_number_a")
  batteryNumberB String      @map("battery_number_b")
  createdAt      DateTime    @default(now()) @map("created_at")
  flightLogs     FlightLog[]

  @@map("batteries")
}

model FlightLog {
  id                String      @id @default(uuid())
  date              DateTime
  takeoffTime       String      @map("takeoff_time")
  duration          String
  locationCoords    String?     @map("location_coords")
  locationName      String?     @map("location_name")
  picId             String?     @map("pic_id")
  voId              String?     @map("vo_id")
  missionType       String      @map("mission_type")
  droneId           String      @map("drone_id")
  serialNumber      String?     @map("serial_number")
  uin               String?     @map("uin")
  technicalFeedback String?     @map("technical_feedback")
  batteryId         String?     @map("battery_id")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")
  battery           Battery?    @relation(fields: [batteryId], references: [id])
  drone             Drone       @relation(fields: [droneId], references: [id], onDelete: Cascade)
  pic               TeamMember? @relation("PIC", fields: [picId], references: [id])
  vo                TeamMember? @relation("VO", fields: [voId], references: [id])

  @@map("flight_logs")
}

model Order {
  id                          String        @id @default(uuid())
  contractNumber              String        @unique @map("contract_number")
  clientName                  String        @map("client_name")
  clientSegment               String        @map("client_segment")
  orderDate                   DateTime      @map("order_date")
  estimatedCompletionDate     DateTime?     @map("estimated_completion_date")
  contractValue               Float         @map("contract_value")
  currency                    String        @default("INR")
  revenueRecognitionStatus    String        @default("Pending") @map("revenue_recognition_status")
  quantity                    Int           @default(1)
  unitPrice                   Float?        @map("unit_price")
  deliveryAddress             String?       @map("delivery_address")
  contactPerson               String?       @map("contact_person")
  contactPhone                String?       @map("contact_phone")
  contactEmail                String?       @map("contact_email")
  paymentTerms                String?       @map("payment_terms")
  paymentStatus               String        @default("Unpaid") @map("payment_status")
  droneModel                  String        @map("drone_model")
  droneType                   String        @map("drone_type")
  weightClass                 String        @map("weight_class")
  payloadConfiguration        String?       @map("payload_configuration")
  flightEnduranceRequirements String?       @map("flight_endurance_requirements")
  softwareAiTier              String?       @map("software_ai_tier")
  dgcaFaaCertificationStatus  String        @default("Pending") @map("dgca_faa_certification_status")
  uin                         String?
  exportLicenseStatus         String?       @map("export_license_status")
  geofencingRequirements      String?       @map("geofencing_requirements")
  bomReadiness                String        @default("Not Ready") @map("bom_readiness")
  manufacturingStage          String        @default("In Design") @map("manufacturing_stage")
  calibrationTestLogs         String?       @map("calibration_test_logs")
  afterSalesAmc               String?       @map("after_sales_amc")
  manufacturingNotes          String?       @map("manufacturing_notes")
  cocData                     String?       @map("coc_data")
  priorityLevel               String        @default("Normal") @map("priority_level")
  qualityCheckStatus          String        @default("Pending") @map("quality_check_status")
  warrantyTerms               String?       @map("warranty_terms")
  specialRequirements         String?       @map("special_requirements")
  internalOrderNotes          String?       @map("internal_order_notes")
  createdAt                   DateTime      @default(now()) @map("created_at")
  updatedAt                   DateTime      @updatedAt @map("updated_at")
  uploads                     OrderUpload[]

  @@map("orders")
}

model OrderUpload {
  id        String   @id @default(uuid())
  orderId   String   @map("order_id")
  fileData  String   @map("file_data")
  fileName  String?  @map("file_name")
  createdAt DateTime @default(now()) @map("created_at")
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_uploads")
}

model SupportTicket {
  id          String           @id @default(uuid())
  subject     String
  status      TicketStatus     @default(OPEN)
  priority    TicketPriority   @default(NORMAL)
  userId      String           @map("user_id")
  hasNewReply Boolean          @default(false) @map("has_new_reply")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  messages    SupportMessage[]
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("support_tickets")
}

model SupportMessage {
  id        String        @id @default(uuid())
  ticketId  String        @map("ticket_id")
  senderId  String        @map("sender_id")
  message   String
  createdAt DateTime      @default(now()) @map("created_at")
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("support_messages")
}

model OtpVerification {
  id        String   @id @default(uuid())
  email     String
  otp       String
  purpose   String
  expiresAt DateTime @map("expires_at")
  verified  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email, otp])
  @@map("otp_verifications")
}

model Component {
  id           String                 @id @default(uuid())
  name         String
  description  String?
  quantity     Int                    @default(0)
  category     String                 @default("Operational")
  createdAt    DateTime               @default(now()) @map("created_at")
  updatedAt    DateTime               @updatedAt @map("updated_at")
  transactions InventoryTransaction[]

  @@map("components")
}

model InventoryTransaction {
  id              String          @id @default(uuid())
  componentId     String          @map("component_id")
  type            TransactionType
  quantity        Int
  date            DateTime        @default(now())
  subcontractorId String?         @map("subcontractor_id")
  userId          String?         @map("user_id")
  takenOutFor     String?         @map("taken_out_for")
  createdAt       DateTime        @default(now()) @map("created_at")
  component       Component       @relation(fields: [componentId], references: [id], onDelete: Cascade)
  subcontractor   Subcontractor?  @relation(fields: [subcontractorId], references: [id])
  user            User?           @relation(fields: [userId], references: [id])

  @@map("inventory_transactions")
}

model Reimbursement {
  id        String   @id @default(uuid())
  name      String
  category  String?  @default("Other")
  amount    Float
  date      DateTime
  billData  String   @map("bill_data")
  status    String   @default("Pending")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reimbursements")
}

model FunnelStage {
  id        String   @id @default(uuid())
  name      String
  order     Int
  color     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  leads     Lead[]

  @@map("funnel_stages")
}

model Lead {
  id          String         @id
  name        String?
  email       String?
  phone       String?
  company     String?
  source      String?
  stageId     String?        @map("stage_id")
  value       Float?
  notes       String?
  convertedAt DateTime?      @map("converted_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  followUps   FollowUp[]
  activities  LeadActivity[]
  stage       FunnelStage?   @relation(fields: [stageId], references: [id])

  @@map("leads")
}

model LeadActivity {
  id        String   @id @default(uuid())
  leadId    String   @map("lead_id")
  type      String
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_activities")
}

model FollowUp {
  id          String    @id @default(uuid())
  leadId      String    @map("lead_id")
  title       String?
  description String?
  scheduledAt DateTime? @map("scheduled_at")
  status      String    @default("PENDING")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("follow_ups")
}

enum Role {
  MANUFACTURING
  DESIGN
  SALES
  SOFTWARE
  ADMINISTRATION
  SUPER_ADMIN
  ADMIN
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TransactionType {
  IN
  OUT
}
