# === DATABASE ===
# PostgreSQL connection string (use Neon for free tier)
# Generate: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/aerosys?schema=public&sslmode=require"

# === AUTHENTICATION ===
# Generate with: openssl rand -hex 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-hex-32-chars"
JWT_SECRET="generate-with-openssl-rand-hex-32-chars"

# === ENVIRONMENT ===
NODE_ENV="development"
NEXT_PUBLIC_API_URL="http://localhost:3000"

# === AI ASSISTANT (Aero) ===
# Get API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY="your-google-gemini-api-key-here"

# === EMAIL SERVICE ===
# For Gmail: Use App Password (not your regular password)
# For other providers: Use provider-specific credentials
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="app-password-not-regular-password"
SMTP_FROM="AeroSky <noreply@aerosysaviation.in>"

# === SECURITY ===
# IP whitelist in CIDR format (comma-separated), restrict in production
ALLOWED_SUBNET="192.168.0.0/24,10.0.0.0/8"

# === RATE LIMITING (OPTIONAL) ===
# Get from: https://console.upstash.com/redis/
# Required for production rate limiting
UPSTASH_REDIS_REST_URL="https://your-redis-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-redis-token"

# === PRODUCTION ONLY ===
# Mapbox token for location features
NEXT_PUBLIC_MAPBOX_TOKEN="your-mapbox-token"

# Production CORS origins (comma-separated)
CORS_ORIGINS="https://app.aerosysaviation.in,https://mobile.aerosysaviation.in"